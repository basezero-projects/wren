{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wren",
  "version": "0.2.3",
  "identifier": "com.syvr.wren",
  "build": {
    "beforeDevCommand": "pnpm run frontend:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Wren",
        "width": 600,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "shadow": false,
        "visible": false,
        "dragDropEnabled": false
      },
      {
        "label": "settings",
        "title": "Wren Settings",
        "url": "index.html#/settings",
        "width": 580,
        "height": 520,
        "minWidth": 580,
        "minHeight": 280,
        "maxWidth": 580,
        "maxHeight": 700,
        "resizable": false,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": false,
        "shadow": false,
        "visible": false,
        "skipTaskbar": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' blob: asset: https://asset.localhost;",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/images/**"]
      },
      "capabilities": ["default"]
    },
    "macOSPrivateApi": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
